# Copy this file to .env.local and fill in the values

# Secret key for JWT signing — must be at least 32 characters
JWT_SECRET=change-this-to-a-long-random-secret-string-32chars

# Admin credentials
ADMIN_USERNAME=admin

# Generate this hash with: npm run hash-password yourpassword
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_THIS_WITH_REAL_BCRYPT_HASH

# Optional: path to data directory (default: ./data)
# DATA_DIR=./data
